    <script>
        // Aura Herbs Global Intelligence System
        const CurrencyManager = {
            rates: { NGN: 1, USD: 1 / 1600, PI: 0.000314 },
            symbols: { NGN: '₦', USD: '$', PI: 'π' },
            current: localStorage.getItem('kedi_currency') || 'NGN',

            init() {
                this.updateUI();
                this.refreshPrices();
                document.querySelectorAll('[data-currency-set]').forEach(btn => {
                    btn.onclick = () => this.set(btn.dataset.currencySet);
                });
            },

            set(code) {
                this.current = code;
                localStorage.setItem('kedi_currency', code);
                this.updateUI();
                this.refreshPrices();
                // We reload to ensure all components (slick, etc) re-render if needed, 
                // but refreshPrices handles the immediate text change.
                location.reload(); 
            },

            updateUI() {
                document.querySelectorAll('.currency-switch-btn').forEach(btn => {
                    const isSelected = btn.dataset.currencySet === this.current;
                    btn.style.background = isSelected ? '#10b981' : 'none';
                    btn.style.color = isSelected ? '#fff' : '#94a3b8';
                    btn.style.borderColor = isSelected ? '#10b981' : '#334155';
                });
            },

            format(amount) {
                return this.symbols[this.current] + (amount * this.rates[this.current]).toLocaleString(undefined, {minimumFractionDigits: 0, maximumFractionDigits: (this.current === 'NGN' ? 0 : 2)});
            },

            refreshPrices() {
                const priceElements = document.querySelectorAll('.new, .old, .price, .product__price span');
                priceElements.forEach(el => {
                    const text = el.innerText;
                    if (text.includes('₦') || text.includes('$') || text.includes('π')) {
                        // Extract number
                        const val = parseFloat(text.replace(/[^\d.]/g, ''));
                        if (!isNaN(val)) {
                            // If it's the first time, store the base price in NGN
                            if (!el.dataset.basePrice) {
                                // Assume input is NGN if it has ₦, or convert to NGN if it has $
                                if (text.includes('$')) el.dataset.basePrice = val * 1600;
                                else if (text.includes('π')) el.dataset.basePrice = val / 0.000314;
                                else el.dataset.basePrice = val;
                            }
                            el.innerText = this.format(parseFloat(el.dataset.basePrice));
                        }
                    }
                });
            }
        };

        const DateHandler = {
            init() {
                const el = document.getElementById('kedi-live-date');
                if (el) {
                    const now = new Date();
                    el.innerText = now.toLocaleDateString('en-US', {
                        weekday: 'long',
                        year: 'numeric',
                        month: 'long',
                        day: 'numeric'
                    });
                }
            }
        };

        const CartLogic = {
            init() {
                const count = JSON.parse(localStorage.getItem('kedi_cart') || '[]').length;
                document.querySelectorAll('#cart-count').forEach(el => el.innerText = count);
            }
        };

        document.addEventListener('DOMContentLoaded', () => {
            CurrencyManager.init();
            DateHandler.init();
            CartLogic.init();
        });
    </script>



